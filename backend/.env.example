PORT=8000
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/smart_construction
REDIS_URL=redis://localhost:6379
JWT_SECRET=change_me
PROJECT_NAME="Smart Construction"
API_V1_STR="/api/v1"

# ============================================
# EMAIL CONFIGURATION
# ============================================
# Choose ONE option below:

# Option 1: Resend API (Recommended)
# Sign up at https://resend.com and get your API key
# RESEND_API_KEY=re_your_api_key_here
# RESEND_FROM_EMAIL=Smart Construction <onboarding@resend.dev>

# Option 2: SMTP (Gmail, Outlook, etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# ============================================
# FRONTEND URL (for email links)
# ============================================
FRONTEND_URL=http://localhost:3000

# ============================================
# OPTIONAL SERVICES
# ============================================

# Google OAuth (optional)
GOOGLE_CLIENT_ID=your-google-client-id

# Cloudinary 
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
