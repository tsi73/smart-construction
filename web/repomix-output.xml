  UserCog,
} from 'lucide-react'

interface SettingsPageProps {
  params: Promise<{ projectId: string }>
}

function SectionHeader({
  icon: Icon,
  title,
  description,
  open,
}: {
  icon: typeof UserCog
  title: string
  description: string
  open: boolean
}) {
