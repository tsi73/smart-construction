export function projectsVisibleToUser(items: ProjectListItem[], user: AuthUser | null): ProjectListItem[] {
  if (!user) return []
  if (user.is_admin) return items
  return items.filter((p) => p.owner_id != null && p.owner_id === user.id)
}

